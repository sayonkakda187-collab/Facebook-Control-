# ─────────────────────────────────────────────────────────────────────────────
# PagePulse — environment template.
# Copy this file to `.env.local` and fill in REAL values there.
# NEVER commit real tokens or secrets. Only this template (.env.example) is committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Facebook / Meta Graph API ──
# Graph API version. We target v25.0 (June 2026). Do not downgrade — deprecated
# Page Insights metrics return invalid-metric errors across ALL versions.
FB_GRAPH_VERSION=v25.0

# App credentials — used to sign requests (appsecret_proof) and extend tokens.
FB_APP_ID=your_app_id_here
FB_APP_SECRET=your_app_secret_here

# Access token — provide ONE of the following:
#   FB_SYSTEM_USER_TOKEN  → PREFERRED. Non-expiring Business "system user" token.
#   FB_PAGE_TOKEN         → Alternative. Long-lived Page token (~60 days; needs refresh).
# Required scopes: pages_read_engagement, read_insights, pages_show_list
#   (+ pages_read_user_content for per-post insights, business_management for system user).
FB_SYSTEM_USER_TOKEN=
FB_PAGE_TOKEN=

# Comma-separated list of Page IDs to track (the Pages you administer).
FB_PAGE_IDS=000000000000000,111111111111111

# ── Database (Neon Postgres) — wired up in Phase 4 ──
DATABASE_URL=postgres://user:password@host.neon.tech/pagepulse?sslmode=require

# ── Cron / job security — wired up in Phase 4 ──
# Random string. Vercel Cron sends it as a Bearer token; the cron route verifies it.
CRON_SECRET=generate_a_long_random_string

# ── Dashboard gate (optional) — wired up later ──
DASHBOARD_PASSWORD=change_me
AUTH_SECRET=generate_a_long_random_string

# ── App ──
NEXT_PUBLIC_APP_NAME=PagePulse
